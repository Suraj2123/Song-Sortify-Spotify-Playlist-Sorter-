# Spotify app Client ID — get this from https://developer.spotify.com/dashboard
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# URL of the running Flask backend.
# When using Expo Go on a physical device, set this to your Mac's local IP, e.g.:
#   EXPO_PUBLIC_BACKEND_URL=http://192.168.x.x:5001
# Leave blank to let the app auto-detect the host from Expo's dev server config.
EXPO_PUBLIC_BACKEND_URL=
